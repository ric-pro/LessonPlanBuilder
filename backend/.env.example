# Server Configuration
PORT=3000
NODE_ENV=development

# Hugging Face Configuration
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL_ENDPOINT=https://api-inference.huggingface.co/models/meta-llama/Llama-2-7b-chat-hf

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIRECTORY=./data/uploads

# Application Configuration
APP_NAME=Lesson Plan Builder API
APP_VERSION=1.0.0
CORS_ORIGIN=*

# Database Configuration (if using external database in future)
# DATABASE_URL=postgresql://username:password@localhost:5432/lesson_plan_builder